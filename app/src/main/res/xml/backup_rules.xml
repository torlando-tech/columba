<?xml version="1.0" encoding="utf-8"?>
<!--
  Backup configuration for Columba

  SECURITY POLICY:
  - Room databases (columba.db + reticulum.db): BACKED UP
    * columba.db holds identities (private keys are Keystore-wrapped),
      conversations, messages, contacts, interfaces, settings.
    * reticulum.db holds RNS routing state (paths, announces, packet
      hashlist, tunnels, ratchets, known destinations).
  - SharedPreferences: BACKED UP
  - Cache: EXCLUDED (Android default)

  The `files/reticulum/` exclusion that earlier versions needed is gone:
  the in-memory-identity refactor (PR #785) stopped writing plaintext
  identity keys there, and reticulum-kt v0.0.5 moved all RNS routing
  state into Room, so nothing in that directory contains user state.
-->
<data-extraction-rules>
    <cloud-backup>
        <include domain="database" path="." />
        <include domain="sharedpref" path="." />
        <include domain="file" path="." />
    </cloud-backup>

    <device-transfer>
        <include domain="database" path="." />
        <include domain="sharedpref" path="." />
        <include domain="file" path="." />
    </device-transfer>
</data-extraction-rules>
