<?xml version="1.0" encoding="utf-8"?>
<!--
  "Work in progress" badge for the EXPERIMENTAL kotlinBackend flavor.
  Wrench glyph (Material "build") in an amber disc, anchored bottom-right.
  Same 108dp / 512-viewport as ic_launcher_foreground so it composites 1:1.
  Disc is kept inside the adaptive-icon circular-mask safe area (center
  ~(380,380), r=78 -> farthest point ~253 < 256 mask radius).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="512"
    android:viewportHeight="512">

    <!-- White separator ring so the badge reads against the icon background -->
    <path
        android:pathData="M380,380 m-78,0 a78,78 0,1 1,156 0 a78,78 0,1 1,-156 0"
        android:fillColor="#FFFFFF" />

    <!-- Amber disc -->
    <path
        android:pathData="M380,380 m-74,0 a74,74 0,1 1,148 0 a74,74 0,1 1,-148 0"
        android:fillColor="#FFB300" />

    <!-- Wrench (Material "build"), scaled ~4x and centered in the disc -->
    <group
        android:pivotX="12"
        android:pivotY="12"
        android:scaleX="4.0"
        android:scaleY="4.0"
        android:translateX="368"
        android:translateY="368">
        <path
            android:pathData="M22.7,19l-9.1,-9.1c0.9,-2.3 0.4,-5 -1.5,-6.9 -2,-2 -5,-2.4 -7.4,-1.3L9,6 6,9 1.6,4.7C0.4,7.1 0.9,10.1 2.9,12.1c1.9,1.9 4.6,2.4 6.9,1.5l9.1,9.1c0.4,0.4 1,0.4 1.4,0l2.3,-2.3c0.5,-0.4 0.5,-1.1 0.1,-1.4z"
            android:fillColor="#1A1A1A" />
    </group>
</vector>
