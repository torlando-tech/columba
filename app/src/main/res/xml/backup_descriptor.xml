<?xml version="1.0" encoding="utf-8"?>
<!--
  Backup configuration for Android 11 and below (legacy format).
  See backup_rules.xml for the Android 12+ equivalent and security policy.
-->
<full-backup-content>
    <include domain="database" path="." />
    <include domain="sharedpref" path="." />
    <include domain="file" path="." />
    <!-- Transient plaintext identity files; scrubbed on cold boot. -->
    <exclude domain="file" path="reticulum/identities" />
</full-backup-content>
